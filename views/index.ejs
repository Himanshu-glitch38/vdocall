<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Echotalk | Meet New People Instantly</title>
    <link rel="stylesheet" href="chatStyle.css">
    <link href="https://fonts.googleapis.com/css2?family=Righteous&display=swap" rel="stylesheet">
</head>
<body>
    <div class="liquid-bg">
        <div class="blob"></div>
        <div class="blob"></div>
    </div>

    <nav class="navbar glass">
        <div class="logo-area">
            <img src="logo.png" alt="Logo" class="main-logo">
            <span class="brand-logo">Echotalk</span>
            <span class="tagline">Instant random video chat with people around the world.</span>
        </div>
        <div class="stats">
            <span id="counter" class="online-now">0,000</span> <small>Strangers Online</small>
            <button id="theme-toggle">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </button>
        </div>
    </nav>

    <main class="wrapper">
        <section class="hero-card glass">
            <p class="announcement">Thousands are online right now. Start talking in seconds.</p>

            <h1>Talk to Random Strangers, Anytime</h1>

            <div class="main-text">
                <p>Discover spontaneous conversations with real people from different countries and cultures. No complicated setup, no long forms, and no delays. Just open the chat and meet someone new right away.</p>
            </div>

            <div class="cta-group">
                <div class="gender-selection">
                    <label class="radio-label">
                        <input type="radio" name="gender" value="male" checked> <span>Male</span>
                    </label>
                    <label class="radio-label">
                        <input type="radio" name="gender" value="female"> <span>Female</span>
                    </label>
                </div>
                <div class="terms-checkbox">
                    <input type="checkbox" id="age-confirm">
                    <label for="age-confirm">I confirm I am 18+ years old</label>
                </div>
                <button id="start-chat-btn" class="liquid-btn">Start Chat Now</button>
                <div id="loading-spinner" class="loading-spinner">
                    <div class="spinner"></div>
                </div>
            </div>

            <div class="legal-links">
                By continuing, you agree to our
                <a href="#" class="blue-link">Terms of Service</a> and
                <a href="#" class="blue-link">Privacy Policy</a>.
            </div>
        </section>

        <section class="visual-grid">
            <div class="collage-wrapper glass">
                <div class="floating-img img1"><img src="pic1.jpg" alt="User"></div>
                <div class="floating-img img2"><img src="pic2.jpg" alt="User"></div>
                <div class="floating-img img3"><img src="pic3.jpg" alt="User"></div>
            </div>
        </section>

        <section class="info-section">
            <div class="info-card glass">
                <h4>Private by Design</h4>
                <p>Your sessions are protected with modern security standards so you can chat with confidence.</p>
            </div>
            <div class="info-card glass">
                <h4>Global Community</h4>
                <p>Meet people from around the world and enjoy fresh conversations every time you connect.</p>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="social-icons">
            <a href="#" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
            <a href="#" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
            </a>
            <a href="#" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
        </div>
        <p>&copy; <span data-current-year>2026</span> Echotalk. All rights reserved.</p>
    </footer>

    <script src="chatScript.js"></script>
</body>
</html>

