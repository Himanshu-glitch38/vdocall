<script src="/socket.io/socket.io.js"></script>

<h1>Index</h1>
<p>IS socket connected? :: <span id="issocketconnected">No</span></p>

<!-- <video id="localVideo"></video> -->
<video id="localVideo" autoplay muted playsinline style="height: 30vh;"></video>

<video id="remoteVideo" autoplay muted playsinline style="height: 60vh;"></video>

<h1>Console:</h1>
<p id="bConsole" style="background-color: black; padding: 10px; font-size: 12px; font-family: monospace; font-weight: bold; border-radius: 5px;">
</p>
<br>
<input id="txt" style="border: 4px solid gray; width: 80%; height: 30px; border-radius: 12px; margin: 4px; padding: 2px;" /> <br> <button style="width: 90px; height: 20px; border-radius: 5px; font-size: 12px;" id="sendBtn">send</button>
<script>
const socket = io();
let PC;
const localVideo = document.getElementById("localVideo");
const remoteVideo = document.getElementById("remoteVideo");

let localStream = null;

let socketConnectionText = document.querySelector("#issocketconnected");
let bConsole = document.querySelector("#bConsole");

let partner = null;

let inp = document.querySelector("#txt");
let sendBtn = document.querySelector("#sendBtn");

async function initMedia() {
  try {
    localStream = await navigator.mediaDevices.getUserMedia({
      video: true,
      audio: true
    });
    localVideo.style.transform = "scaleX(-1)";
    localVideo.srcObject = localStream;

    setInterval(() => {
      console.log(localStream);
    }, 5000)
  } catch (err) {
    alert("Camera and microphone permission required.");
    console.error(err);
  }
}
initMedia();

function createPeer() {
  if (PC) return; // prevent duplicate

  PC = new RTCPeerConnection({
    iceServers: [
      { urls: "stun:stun.l.google.com:19302" },
      { urls: "stun:stun1.l.google.com:19302" },
      { urls: "stun:stun2.l.google.com:19302" },
      { urls: "stun:stun3.l.google.com:19302" },
      { urls: "stun:stun4.l.google.com:19302" }
    ]
  });

  // on remote video stream receive
  PC.ontrack = (event) => {
    remoteVideo.srcObject = event.streams[0];
  };


  // Add local tracks
  localStream.getTracks().forEach(track => {
    PC.addTrack(track, localStream);
  });

   // Connection state monitoring
   PC.onconnectionstatechange = () => {
    if (
      PC.connectionState === "disconnected" ||
      PC.connectionState === "failed" ||
      PC.connectionState === "closed"
    ) {
      cleanupPeer();
    }
  };
  
}

sendBtn.addEventListener("click", () => {
  let txtinp = inp.value.trim();
  if(!txtinp) {
    return  logger.error("Please enter a valid message!");
  }

  if(!partner) {
    logger.warn("you dont have partner to sendf");
    inp.value = "";
    return;
  }
  
  socket.emit("message", txtinp, (feedback) => {
    if(feedback === true){
    logger.success(`you sent: ${txtinp}`);
    } else {
      return logger.error(feedback);
    }
  });
  inp.value = "";
  

});

socket.on('message', (msg) => {
  logger.success(`Stranger: ${msg}`);
});



let logger = {
    log(message) {
        bConsole.innerHTML += "<span style='color: gray; font-size: 8px;'>"+(new Date()).toLocaleTimeString() + "|  </span>  " + "<span style='color: gray;'>" + message + "</span> <br> <br>";
    },
    error(message) {
        bConsole.innerHTML += "<span style='color: gray; font-size: 8px;'>"+(new Date()).toLocaleTimeString() + "|  </span>  " + "<span style='color: red;'>" + message + "</span> <br> <br>";
    },
    warn(message) {
        bConsole.innerHTML += "<span style='color: gray; font-size: 8px;'>"+(new Date()).toLocaleTimeString() + "|  </span>  " + "<span style='color: orange;'>" + message + "</span> <br> <br>";
    },
    success(message) {
        bConsole.innerHTML += "<span style='color: gray; font-size: 8px;'>"+(new Date()).toLocaleTimeString() + "|  </span>  " + "<span style='color: lime;'>" + message + "</span> <br> <br>";
    },
    info(message) {
        bConsole.innerHTML += "<span style='color: gray; font-size: 8px;'>"+(new Date()).toLocaleTimeString() + "|  </span>  " + "<span style='color: cyan;'>" + message + "</span> <br> <br>";
    },
    debug(message) {
        bConsole.innerHTML += "<span style='color: gray; font-size: 8px;'>"+(new Date()).toLocaleTimeString() + "|  </span>  " + "<span style='color: yellow;'>" + message + "</span> <br> <br>";
    }
};

socket.on('connect', () => {
  console.log('Successfully connected to the server with ID:', socket.id);
  socketConnectionText.innerHTML = "Yes";
 logger.success("Successfully connected to the server with ID: " + socket.id);
});

socket.on('disconnect', () => {
  partner = null;
  console.log('Disconnected from the server');
  socketConnectionText.innerHTML = "No";
  logger.error("Disconnected from the server");
});

socket.on("waiting", () => {
  partner = null;
  logger.info("Waiting for a partner...");
});

socket.on("partner-disconnected", () => {
  partner = null;
  logger.warn("your Partner disconnected");
});

socket.on("matched", (partnerId) => {
  partner = partnerId;
  logger.success("Matched with partner with ID: " + partnerId);

  logger.debug(`${socket.id} (you) 🤝 ${partnerId} (stranger)`);
});




