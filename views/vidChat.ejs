<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Echotalk | Chat</title>
    <script src="/socket.io/socket.io.js"></script>
    <link rel="stylesheet" href="chatStyle.css">
    <link href="https://fonts.googleapis.com/css2?family=Righteous&display=swap" rel="stylesheet">

</head>
<body class="chat-page in-chat">
    <div class="liquid-bg">
        <div class="blob"></div>
        <div class="blob"></div>
    </div>

    <nav class="navbar glass">
        <div class="logo-area">
            <img src="logo.png" alt="Logo" class="main-logo">
            <span class="brand-logo">Echotalk</span>
            <span class="tagline">Instant random video chat with people around the world.</span>
        </div>
        <div class="stats">
            <div id="counter" class="online-now" class="odometer">30,447</div> <small>Strangers Online</small>
            <button id="theme-toggle">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </button>
        </div>
    </nav>

    <main class="wrapper">
        <section id="video-chat-area" class="glass video-chat-area" style="display:block;">
            <div class="video-chat-layout">
                <div class="video-container">
                    <div class="video-wrapper">
                        <h3>You</h3>
                        <video id="localVideo" autoplay muted playsinline></video>
                        <button id="muteBtn" class="mute-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
                        </button>
                    </div>
                    <div class="video-wrapper">
                        <h3>Stranger</h3>
                        <video id="remoteVideo" autoplay playsinline></video>
                        <div id="strangerOverlay" class="stranger-overlay">
                            <div class="stranger-avatar">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"></circle><path d="M4 20a8 8 0 0 1 16 0"></path></svg>
                            </div>
                            <p id="strangerStatus">Searching for a stranger...</p>
                        </div>
                        <button id="reportBtn" class="report-btn">Report</button>
                    </div>
                </div>
                <div id="videoResizeHandle" class="video-resize-handle" aria-label="Resize video area" role="separator">
                    <span></span>
                </div>

                <div class="chat-box">
                    <div id="chat-log">
                        <div class="match-loading">
                            <div class="match-spinner"></div>
                            <p>Searching for a stranger...</p>
                        </div>
                    </div>
                    <div class="chat-input-area">
                        <input type="text" id="chat-msg" placeholder="Type a message...">
                        <button id="send-btn">Send</button>
                    </div>
                </div>
            </div>
            <div class="chat-controls">
                <button id="skipBtn" class="liquid-btn control-btn control-btn-skip">Skip</button>
                <button id="stopChat" class="liquid-btn control-btn control-btn-stop">Stop</button>
                <button id="screenshotBtn" class="liquid-btn control-btn control-btn-icon control-btn-shot" aria-label="Take screenshot">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon control-icon" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                </button>
                <button id="fullscreenBtn" class="liquid-btn control-btn control-btn-icon control-btn-full" aria-label="Toggle fullscreen">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon control-icon" viewBox="0 0 24 24"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
                </button>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="social-icons">
            <a href="#" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
            <a href="#" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
            </a>
            <a href="#" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
        </div>
        <p>&copy; <span data-current-year>2026</span> Echotalk. All rights reserved.</p>
    </footer>
    <script src="sockRTC.js"></script>
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <script src="chatScript.js"></script>
</body>
</html>